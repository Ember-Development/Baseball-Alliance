PORT=3000
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/baseball_alliance?schema=public"

# Required for POST /api/auth/login — use a long random string in production
JWT_SECRET="replace-with-a-long-random-secret"
JWT_EXPIRES_IN="7d"

# BAMS magic-link sign-in (Playbook members)
FRONTEND_URL="http://localhost:5173"
MAGIC_LINK_TTL_MINUTES=30

# Resend (required in production to email BAMS magic links)
# RESEND_API_KEY=re_xxxxxxxx
# EMAIL_FROM must use a domain verified in Resend
# EMAIL_FROM="Baseball Alliance <noreply@baseballalliance.co>"

# BAMS college-match-service (server-side proxy for event CSV matching)
BAMS_API_URL="https://api.bams.baseballalliance.co"
